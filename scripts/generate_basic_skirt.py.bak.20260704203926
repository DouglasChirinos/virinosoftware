from __future__ import annotations

import sys
from pathlib import Path

# Permite ejecutar este archivo directamente:
#   python3 scripts/generate_basic_skirt.py
# sin depender de exportar PYTHONPATH manualmente.
PROJECT_ROOT = Path(__file__).resolve().parents[1]
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

from engine.exports.svg.writer import export_svg
from engine.garments.skirt.basic import draft_basic_skirt
from engine.measurements.body import BodyMeasurements


def main() -> None:
    measurements = BodyMeasurements(waist=72, hip=100, skirt_length=60, hip_depth=20)
    pieces = draft_basic_skirt(measurements)
    output = export_svg(pieces, PROJECT_ROOT / "exports/svg/falda_basica_mvp.svg")
    print(f"SVG generado: {output}")


if __name__ == "__main__":
    main()
