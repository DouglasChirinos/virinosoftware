from __future__ import annotations

from dataclasses import dataclass
from pathlib import Path
from typing import Iterable

from engine.geometry.point import Point
from engine.geometry.line import Line
from engine.measurements.body import BodyMeasurements


@dataclass(frozen=True)
class PatternPiece:
    """Pieza geometrica basica de patronaje."""

    name: str
    lines: list[Line]

    @property
    def points(self) -> list[Point]:
        pts: list[Point] = []
        for line in self.lines:
            pts.append(line.start)
            pts.append(line.end)
        return pts


class BasicSkirtDraft:
    """Falda basica MVP.

    Convencion:
    - Unidades en centimetros.
    - Eje X hacia la derecha.
    - Eje Y hacia abajo.
    - Origen en esquina superior izquierda del delantero.
    """

    def __init__(self, measurements: BodyMeasurements) -> None:
        self.measurements = measurements

    def draft(self) -> list[PatternPiece]:
        m = self.measurements
        quarter_hip = (m.hip / 4.0) + 2.0
        length = m.skirt_length
        waist_width = (m.waist / 4.0) + 1.0
        dart_depth = 2.0
        dart_length = 10.0

        # Delantero rectangular simplificado con cintura reducida por pinza implicita.
        a = Point(0, 0)
        b = Point(quarter_hip, 0)
        c = Point(quarter_hip, length)
        d = Point(0, length)

        waist_end = Point(waist_width, 0)
        dart_center = Point(waist_width / 2.0, 0)
        dart_left = Point(dart_center.x - dart_depth / 2.0, 0)
        dart_tip = Point(dart_center.x, dart_length)
        dart_right = Point(dart_center.x + dart_depth / 2.0, 0)

        front = PatternPiece(
            name='falda_basica_delantero',
            lines=[
                Line(a, waist_end),
                Line(waist_end, c),
                Line(c, d),
                Line(d, a),
                Line(dart_left, dart_tip),
                Line(dart_tip, dart_right),
            ],
        )

        # Espalda desplazada a la derecha para visualizar como segunda pieza.
        offset = quarter_hip + 8.0
        ea = Point(offset, 0)
        eb = Point(offset + quarter_hip, 0)
        ec = Point(offset + quarter_hip, length)
        ed = Point(offset, length)
        e_waist_end = Point(offset + waist_width, 0)
        e_dart_center = Point(offset + waist_width / 2.0, 0)
        e_dart_left = Point(e_dart_center.x - dart_depth / 2.0, 0)
        e_dart_tip = Point(e_dart_center.x, dart_length + 2.0)
        e_dart_right = Point(e_dart_center.x + dart_depth / 2.0, 0)

        back = PatternPiece(
            name='falda_basica_espalda',
            lines=[
                Line(ea, e_waist_end),
                Line(e_waist_end, ec),
                Line(ec, ed),
                Line(ed, ea),
                Line(e_dart_left, e_dart_tip),
                Line(e_dart_tip, e_dart_right),
            ],
        )

        return [front, back]
