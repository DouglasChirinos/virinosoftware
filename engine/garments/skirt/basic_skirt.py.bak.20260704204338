from __future__ import annotations

from dataclasses import dataclass

from engine.geometry.point import Point
from engine.measurements.body import BodyMeasurements
from engine.patterns.piece import PatternPiece


@dataclass(frozen=True)
class BasicSkirtDraft:
    """Generador MVP de falda basica.

    No pretende resolver patronaje industrial completo.
    Su objetivo es validar el flujo:
    medidas -> puntos -> lineas -> exportaciones.
    """

    measurements: BodyMeasurements

    def draft_front(self) -> PatternPiece:
        m = self.measurements
        waist_quarter = m.waist / 4 + m.ease / 2
        hip_quarter = m.hip / 4 + m.ease / 2
        hip_depth = 20.0

        piece = PatternPiece(name="Falda basica delantera")

        a = piece.add_point("A_cintura_centro", Point(0, 0))
        b = piece.add_point("B_cintura_costado", Point(waist_quarter, 0))
        c = piece.add_point("C_cadera_centro", Point(0, hip_depth))
        d = piece.add_point("D_cadera_costado", Point(hip_quarter, hip_depth))
        e = piece.add_point("E_bajo_centro", Point(0, m.skirt_length))
        f = piece.add_point("F_bajo_costado", Point(hip_quarter, m.skirt_length))

        piece.add_line(a, b, "cintura")
        piece.add_line(b, d, "costado cintura-cadera")
        piece.add_line(d, f, "costado")
        piece.add_line(f, e, "bajo")
        piece.add_line(e, c, "centro frente")
        piece.add_line(c, a, "centro frente superior")
        piece.add_line(c, d, "linea de cadera")

        dart_center = waist_quarter / 2
        dart_width = min(3.0, max(1.5, (m.hip - m.waist) / 12))
        dart_length = 10.0
        p1 = piece.add_point("Pinza_izq", Point(dart_center - dart_width / 2, 0))
        p2 = piece.add_point("Pinza_punta", Point(dart_center, dart_length))
        p3 = piece.add_point("Pinza_der", Point(dart_center + dart_width / 2, 0))
        piece.add_line(p1, p2, "pinza izquierda")
        piece.add_line(p2, p3, "pinza derecha")

        piece.add_annotation("MVP tecnico: falda basica delantera sin margenes de costura.")
        return piece

    def draft(self) -> list[PatternPiece]:
        return [self.draft_front()]
