from __future__ import annotations

from pathlib import Path

from engine.patterns.piece import PatternPiece


def _normalize_pieces(pieces: PatternPiece | list[PatternPiece] | tuple[PatternPiece, ...]) -> list[PatternPiece]:
    if isinstance(pieces, PatternPiece):
        return [pieces]
    return list(pieces)


def export_dxf(
    pieces: PatternPiece | list[PatternPiece] | tuple[PatternPiece, ...],
    output_path: str | Path,
) -> Path:
    try:
        import ezdxf
    except ImportError as exc:
        raise RuntimeError("Falta ezdxf. Ejecuta: python3 -m pip install -r requirements.txt") from exc

    output = Path(output_path)
    output.parent.mkdir(parents=True, exist_ok=True)

    doc = ezdxf.new("R2010")
    msp = doc.modelspace()

    for piece in _normalize_pieces(pieces):
        layer = piece.name[:31]
        if layer not in doc.layers:
            doc.layers.add(layer)
        for line in piece.lines:
            msp.add_line(
                (line.start.x, -line.start.y),
                (line.end.x, -line.end.y),
                dxfattribs={"layer": layer},
            )

    doc.saveas(output)
    return output
