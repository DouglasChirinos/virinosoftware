from __future__ import annotations

from pathlib import Path

from reportlab.lib.pagesizes import A4
from reportlab.pdfgen import canvas

CM_TO_PT = 28.3464567


def export_pdf(pattern_pieces, output_path: str | Path) -> Path:
    output = Path(output_path)
    output.parent.mkdir(parents=True, exist_ok=True)

    c = canvas.Canvas(str(output), pagesize=A4)
    width, height = A4
    margin = 30

    c.setFont('Helvetica-Bold', 12)
    c.drawString(margin, height - margin, 'Falda basica MVP')
    c.setFont('Helvetica', 8)
    c.drawString(margin, height - margin - 14, 'Unidades fuente en cm. Vista escalada para revision tecnica.')

    # Escala simple para que quepa en A4
    all_points = [p for piece in pattern_pieces for p in piece.points]
    max_x = max((p.x for p in all_points), default=1)
    max_y = max((p.y for p in all_points), default=1)
    scale_x = (width - 2 * margin) / max(max_x * CM_TO_PT, 1)
    scale_y = (height - 90) / max(max_y * CM_TO_PT, 1)
    scale = min(scale_x, scale_y, 1.0)

    origin_x = margin
    origin_y = height - 70

    for piece in pattern_pieces:
        for line in piece.lines:
            x1 = origin_x + line.start.x * CM_TO_PT * scale
            y1 = origin_y - line.start.y * CM_TO_PT * scale
            x2 = origin_x + line.end.x * CM_TO_PT * scale
            y2 = origin_y - line.end.y * CM_TO_PT * scale
            c.line(x1, y1, x2, y2)
        pts = piece.points
        if pts:
            min_x = min(p.x for p in pts)
            min_y = min(p.y for p in pts)
            c.drawString(origin_x + min_x * CM_TO_PT * scale, origin_y - min_y * CM_TO_PT * scale + 12, piece.name)

    c.showPage()
    c.save()
    return output
