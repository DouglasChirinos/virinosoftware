PYTHON ?= python3
VENV ?= .venv
PIP := $(VENV)/bin/pip
PY := $(VENV)/bin/python
PYTHONPATH := .
export PYTHONPATH

.PHONY: venv install run run-gui generate-skirt test lint compile docker-build docker-up docker-down clean

venv:
	$(PYTHON) -m venv $(VENV)

install: venv
	$(PIP) install --upgrade pip
	$(PIP) install -r requirements.txt

run: run-gui

run-gui:
	$(PY) -m app.main

generate-skirt:
	$(PY) scripts/generate_basic_skirt.py

test:
	$(PY) -m pytest -q

lint:
	$(PY) -m ruff check .

compile:
	$(PYTHON) -m compileall app engine scripts tests

docker-build:
	docker compose build

docker-up:
	docker compose up --build

docker-down:
	docker compose down

clean:
	rm -rf .pytest_cache .ruff_cache __pycache__
	find . -type d -name __pycache__ -prune -exec rm -rf {} +

generate-all-exports:
	.venv/bin/python scripts/generate_basic_skirt_all_exports.py

show-exports:
	ls -lh exports/svg exports/dxf exports/pdf
